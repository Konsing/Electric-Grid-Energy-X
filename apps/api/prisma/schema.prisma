generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────

enum Role {
  ADMIN
  TECHNICIAN
  CUSTOMER
}

enum AccountStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum MeterStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
}

enum ReadingSource {
  MANUAL
  SMART_METER
  ESTIMATED
}

enum BillingStatus {
  PENDING
  ISSUED
  PAID
  OVERDUE
  CANCELLED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum PaymentMethod {
  CREDIT_CARD
  BANK_TRANSFER
  AUTO_PAY
}

enum NotificationType {
  BILLING
  OUTAGE
  USAGE_ALERT
  MAINTENANCE
  GENERAL
}

enum OutageStatus {
  REPORTED
  CONFIRMED
  IN_PROGRESS
  RESOLVED
}

enum OutageSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  STATUS_CHANGE
  LOGIN
  LOGOUT
}

// ─── Models ───────────────────────────────────────────

model User {
  id          String    @id @default(uuid())
  email       String    @unique
  firebaseUid String    @unique
  passwordHash String?  // Only used with MOCK_AUTH (LocalJwt)
  role        Role      @default(CUSTOMER)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime? // Soft delete — GDPR right-to-erasure

  account   Account?
  auditLogs AuditLog[]

  @@index([email])
  @@index([firebaseUid])
  @@index([deletedAt])
}

model Account {
  id             String        @id @default(uuid())
  userId         String        @unique
  accountNumber  String        @unique @default(uuid())
  firstName      String        // PII
  lastName       String        // PII
  phone          String?       // PII
  serviceAddress String        // PII
  status         AccountStatus @default(ACTIVE)
  fcmToken       String?       // Push notification target
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  user          User           @relation(fields: [userId], references: [id])
  meters        Meter[]
  billingCycles BillingCycle[]
  notifications Notification[]

  @@index([accountNumber])
  @@index([status])
}

model Meter {
  id            String      @id @default(uuid())
  accountId     String
  serialNumber  String      @unique
  model         String
  location      String
  status        MeterStatus @default(ACTIVE)
  installedAt   DateTime    @default(now())
  lastReadingAt DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  account  Account        @relation(fields: [accountId], references: [id])
  readings MeterReading[]

  @@index([accountId, status])
}

model MeterReading {
  id             String        @id @default(uuid())
  meterId        String
  readingValue   Float
  readingDate    DateTime
  source         ReadingSource @default(MANUAL)
  idempotencyKey String        @unique
  createdAt      DateTime      @default(now())

  meter Meter @relation(fields: [meterId], references: [id])

  @@unique([meterId, readingDate, source])
  @@index([meterId, readingDate])
  @@index([readingDate])
}

model BillingCycle {
  id        String        @id @default(uuid())
  accountId String
  startDate DateTime
  endDate   DateTime
  totalKwh  Float         @default(0)
  amountDue Float         @default(0)
  status    BillingStatus @default(PENDING)
  dueDate   DateTime
  version   Int           @default(1) // Optimistic locking
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  account Account  @relation(fields: [accountId], references: [id])
  payment Payment?

  @@index([accountId, status])
  @@index([accountId, dueDate])
  @@index([status, dueDate])
}

model Payment {
  id             String        @id @default(uuid())
  billingCycleId String        @unique // DB-enforced 1:1 — prevents double payment
  amount         Float
  method         PaymentMethod
  status         PaymentStatus @default(PENDING)
  idempotencyKey String        @unique
  attempts       Int           @default(1)
  lastError      String?
  nextRetryAt    DateTime?
  paidAt         DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  billingCycle BillingCycle @relation(fields: [billingCycleId], references: [id])

  @@index([status, nextRetryAt])
}

model Notification {
  id             String           @id @default(uuid())
  accountId      String
  type           NotificationType
  title          String
  message        String
  idempotencyKey String           @unique
  readAt         DateTime?
  createdAt      DateTime         @default(now())

  account Account @relation(fields: [accountId], references: [id])

  @@index([accountId, readAt])
  @@index([accountId, createdAt])
  @@index([createdAt])
}

model Outage {
  id                  String        @id @default(uuid())
  affectedArea        String
  status              OutageStatus  @default(REPORTED)
  severity            OutageSeverity
  title               String
  description         String
  estimatedResolution DateTime?
  startedAt           DateTime      @default(now())
  resolvedAt          DateTime?
  reportedById        String
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  @@index([status, startedAt])
  @@index([status, severity])
  @@index([affectedArea, status])
}

model AuditLog {
  id         String      @id @default(uuid())
  userId     String?
  action     AuditAction
  resource   String
  resourceId String
  traceId    String
  spanId     String?
  metadata   Json?
  createdAt  DateTime    @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([resource, resourceId])
  @@index([userId, createdAt])
  @@index([traceId])
  @@index([createdAt])
}
